# Frontend
# Set this when frontend is hosted on a different domain than the API.
# Example: VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=

# Server
SERVER_PORT=8787
SESSION_TTL_HOURS=24
# Legacy fallback salt (used to verify old SHA-256 hashes during migration)
AUTH_PASSWORD_SALT=change-this-salt
AUTH_PBKDF2_ITERATIONS=210000
SESSION_TOKEN_PEPPER=change-this-session-pepper
# Explicit proxy trust control (false, true, 1, or a trusted proxy subnet value)
TRUST_PROXY=false
# Comma-separated allowed origins for browser requests to API.
# Example: CORS_ORIGIN=https://compli-pay-ai.vercel.app,https://preview.example.com
# Use * only for demo/testing.
CORS_ORIGIN=*

# Alibaba Model Studio / DashScope
# Set one of these:
DASHSCOPE_API_KEY=
MODEL_STUDIO_API_KEY=

# OpenAI-compatible endpoint for Qwen (international)
AI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus

# Optional
AI_SYSTEM_PROMPT=You are CompliPay AI assistant for institutional stablecoin operations. Provide concise, compliant guidance focused on KYC, KYT, AML, Travel Rule, settlement, and auditability.

# Optional compliance provider connector
COMPLIANCE_PROVIDER_URL=
COMPLIANCE_PROVIDER_KEY=

# Optional wallet balance RPC override
SOLANA_WALLET_CLUSTER=devnet
SOLANA_RPC_ENDPOINT=
# Optional SPL mint mapping for accurate USDC/USDT wallet balance refresh
USDC_TOKEN_MINT=
USDT_TOKEN_MINT=

# Optional SPL execution tuning
SPL_DEFAULT_DECIMALS=6
MEMO_PROGRAM_ID=MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr
