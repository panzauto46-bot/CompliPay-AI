# Server
SERVER_PORT=8787
SESSION_TTL_HOURS=24
AUTH_PASSWORD_SALT=change-this-salt

# Alibaba Model Studio / DashScope
# Set one of these:
DASHSCOPE_API_KEY=
MODEL_STUDIO_API_KEY=

# OpenAI-compatible endpoint for Qwen (international)
AI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus

# Optional
AI_SYSTEM_PROMPT=You are CompliPay AI assistant for institutional stablecoin operations. Provide concise, compliant guidance focused on KYC, KYT, AML, Travel Rule, settlement, and auditability.

# Optional compliance provider connector
COMPLIANCE_PROVIDER_URL=
COMPLIANCE_PROVIDER_KEY=

# Optional wallet balance RPC override
SOLANA_WALLET_CLUSTER=devnet
SOLANA_RPC_ENDPOINT=
